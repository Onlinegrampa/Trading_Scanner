{
  "name": "ross-scanner",
  "version": "1.0.0",
  "description": "Professional stock scanner with CLI and web dashboard powered by Polygon.io",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "start": "node dist/index.js",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"ts-node src/index.ts\" \"vite --config vite.config.ts\"",
    "dev:backend": "ts-node src/index.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
    "cli": "ts-node src/index.ts --cli",
    "web": "ts-node src/index.ts --web"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2",
    "vite": "^8.0.9"
  }
}
