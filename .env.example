# Polygon.io API Key
# Get yours at https://polygon.io/dashboard
POLYGON_API_KEY=your_api_key_here

# Web dashboard port (default: 3000)
PORT=3000

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Schwab API (optional) ─────────────────────────────────────────────────
# Register at https://developer.schwab.com, create an Individual Trader app.
# You can also configure these via the Settings tab in the dashboard.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:3000/auth/schwab/callback
SCHWAB_ACCOUNT_ID=

# ── TOS Alert Log Watcher (optional) ─────────────────────────────────────
# Full path to your thinkorswim alerts log file.
# Example (Windows): C:\Users\YourName\Documents\thinkorswim\alerts.log
TOS_ALERT_LOG_PATH=
